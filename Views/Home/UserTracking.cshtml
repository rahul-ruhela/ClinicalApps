@{
    ViewData["Title"] = "User tracking";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Tracking Dashboard - Clinical Document Assistant</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />


</head>
<body>
    <nav class="navbar">
        <div class="navbar-container">
            <a href="/" class="logo">
                <div class="logo-icon"><svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z" /></svg></div>
                <span class="logo-text">Clinical<span>Intelligence</span>AI</span>
            </a>
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/home/demo">Demo</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="page-header">
            <h1>User Tracking Dashboard</h1>
            <p>Monitor visitors who have accessed the discharge summary demo</p>
        </div>

        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-icon blue">👥</div>
                <div class="stat-value" id="totalUsers">0</div>
                <div class="stat-label">Total Visitors</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green">📅</div>
                <div class="stat-value" id="todayUsers">0</div>
                <div class="stat-label">Today's Visitors</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon purple">📧</div>
                <div class="stat-value" id="uniqueEmails">0</div>
                <div class="stat-label">Unique Emails</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon orange">🕐</div>
                <div class="stat-value" id="lastVisit">-</div>
                <div class="stat-label">Last Visit</div>
            </div>
        </div>

        <div class="table-container">
            <div class="table-header">
                <h2>Visitor Records</h2>
                <div class="table-actions">
                    <button class="btn btn-outline" onclick="refreshData()">Refresh</button>
                    <button class="btn btn-primary" onclick="exportData()">Export CSV</button>
                    <button class="btn btn-danger" onclick="clearAllData()">Clear All</button>
                </div>
            </div>

            <div id="loadingState" class="loading">
                <div class="spinner"></div>
                <p>Loading visitor data...</p>
            </div>

            <div id="emptyState" class="empty-state" style="display: none;">
                <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" /></svg>
                <h3>No visitors yet</h3>
                <p>Visitor data will appear here once users access the demo</p>
            </div>

            <table id="userTable" style="display: none;">
                <thead>
                    <tr>
                        <th>Visitor</th>
                        <th>Source Page</th>
                        <th>Date & Time</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="userTableBody">
                </tbody>
            </table>
        </div>
    </div>

    <script src="~/js/js0.js"></script>
</body>
</html>
